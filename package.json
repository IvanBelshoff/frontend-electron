{
  "name": "frontend-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Portal de administração de dashboards DataDash",
  "author": "DataDash",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "dev:electron:build": "tsc -p tsconfig.electron.json",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "prebuild:pack": "node scripts/prebuild-pack.mjs",
    "build": "npm run build:renderer && npm run dev:electron:build && npm run prebuild:pack && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.7",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.32",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.87.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "@xyflow/react": "^12.11.1",
    "ai": "^7.0.29",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^6.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.2",
    "remark-gfm": "^4.0.1"
  }
}
